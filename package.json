{
  "name": "starblog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply starblog-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply starblog-db --remote",
    "hash": "node scripts/hash-password.mjs",
    "gen:seed": "node scripts/generate-seed.mjs",
    "db:seed:local": "node scripts/generate-seed.mjs && wrangler d1 execute starblog-db --local --file=./drizzle/seed.sql",
    "db:seed:remote": "node scripts/generate-seed.mjs && wrangler d1 execute starblog-db --remote --file=./drizzle/seed.sql",
    "db:studio": "drizzle-kit studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:p0": "playwright test --grep @P0",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@shikijs/rehype": "^4.0.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "next": "^15.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-cjk-friendly": "^2.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.2",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.6",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.87.0"
  }
}
